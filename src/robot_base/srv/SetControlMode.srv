# Request
# 说明：本服务用于生成协议中的 status_mask/status_value（TAG 0x11/0x12）以及一次性下发参数。
# - 所有“*_cmd”字段：0 表示不修改；非 0 表示本次需要修改对应位。
# - status_word 位定义以最新版通讯协议为准。

# 右/左轮电机使能（bit0-bit1 / bit3-bit4）：0不修改 1使能 2失能
uint8 right_wheel_enable_cmd
uint8 left_wheel_enable_cmd

# 右/左轮电机复位（bit2 / bit5）：0不修改 1复位
uint8 right_wheel_reset_cmd
uint8 left_wheel_reset_cmd

# 使能搬运/卸载动作（bit9） : 0不修改 1使能 2失能
uint8 action_enable_cmd

# 搬运/卸载/slave类型（bit10-bit11） ： 0不修改 1搬运 2卸载 3slave
uint8 action_type

# 充电（bit14）：0不修改 1打开 2关闭
uint8 charging_on_cmd

#一次性下发参数
#花盆架索引
int8 rack_index
---
# Response
bool success
